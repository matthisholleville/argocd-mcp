# ArgoCD connection
ARGOCD_BASE_URL=https://argocd.example.com
ARGOCD_TOKEN=your-argocd-token

# Auth mode: "token" (default) or "oauth" (Dex SSO)
AUTH_MODE=token

# Override if ArgoCD spec is at a non-standard path
# ARGOCD_SPEC_URL=

# Only needed for AUTH_MODE=oauth
# SERVER_BASE_URL=https://mcp.example.com

# Security: block all write operations (POST, PUT, PATCH, DELETE)
# DISABLE_WRITE=true

# Security: restrict to specific resource types (comma-separated OpenAPI tags)
# Combines with DISABLE_WRITE for fine-grained control.
# Available tags: AccountService, ApplicationService, ApplicationSetService,
#   CertificateService, ClusterService, GPGKeyService, NotificationService,
#   ProjectService, RepoCredsService, RepositoryService, SessionService,
#   SettingsService, VersionService
# ALLOWED_RESOURCES=ApplicationService,ProjectService
