# ArgoCD connection
ARGOCD_BASE_URL=https://argocd.example.com
ARGOCD_TOKEN=your-argocd-token

# Auth mode: "token" (default) or "oauth" (Dex SSO)
AUTH_MODE=token

# Override if ArgoCD spec is at a non-standard path
# ARGOCD_SPEC_URL=

# Only needed for AUTH_MODE=oauth
# SERVER_BASE_URL=https://mcp.example.com
